# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://argus:argus@localhost:5432/argus

# If DATABASE_URL is omitted, ARGUS uses sqlite:///./argus.db.
DATABASE_URL=

# Comma-separated browser origins allowed to call the API.
# Add your Vercel production URL here, for example:
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3100,http://127.0.0.1:3100,null

# Keep disabled for reliable local demos. Set true to attempt public HTML search pages.
ENABLE_LIVE_SEARCH=false

# Primary mode: online, offline, demo, or auto.
ARGUS_MODE=auto

# Offline competition mode uses a local public-source corpus and does not call the internet.
ARGUS_OFFLINE_MODE=true

# Demo mode uses deterministic multi-source research data for hackathon/demo reliability.
ARGUS_DEMO_MODE=true

REQUEST_TIMEOUT_SECONDS=12
ARGUS_SEARCH_TIMEOUT_SECONDS=10
ARGUS_MAX_CONCURRENCY=5
ARGUS_CACHE_TTL_SECONDS=86400
ARGUS_CRAWL_CACHE_TTL_SECONDS=86400
ARGUS_MAX_SOURCE_TARGETS=5
ARGUS_MAX_RESULTS_PER_SOURCE=10
ARGUS_MAX_SOURCE_QUERIES=12
ARGUS_MAX_RESULTS_PER_QUERY=10
ARGUS_MAX_PAGES_PER_SITE=4
ARGUS_MAX_PAGES_PER_SOURCE=3

# Production safe mode keeps Render health checks fast by making startup DB/recovery work non-blocking.
ARGUS_PRODUCTION_SAFE_MODE=false

# Vercel frontend environment variable:
# NEXT_PUBLIC_ARGUS_API_URL=https://your-render-backend.onrender.com
